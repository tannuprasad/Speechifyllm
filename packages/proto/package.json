{
	"name": "@chirp/proto",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./protos/*": "./protos/*"
	},
	"scripts": {
		"proto:generate": "pnpm exec protoc --ts_out ./generated --proto_path ./protos ./protos/*.proto",
		"typecheck": "tsc --noEmit",
		"build": "pnpm run proto:generate"
	},
	"dependencies": {
		"@protobuf-ts/runtime": "^2.9.4",
		"@protobuf-ts/runtime-rpc": "^2.9.4"
	},
	"devDependencies": {
		"@protobuf-ts/plugin": "^2.9.4",
		"@protobuf-ts/protoc": "^2.9.4",
		"typescript": "^5.7.2"
	}
}
